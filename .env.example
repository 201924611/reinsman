# Claude Agent SDK authentication — you only need one of the two below.
# 1) API key method (recommended: reliable for unattended 24h operation)
ANTHROPIC_API_KEY=sk-ant-...

# 2) Or use the Claude Code CLI login session (leave the key blank to fall back to CLI auth)

# Model used by the central agent
AGENT_MODEL=claude-opus-4-8

# Default model for sub-agents (a lower tier is fine to reduce cost)
SUBAGENT_MODEL=claude-sonnet-4-6

# HTTP server binding
HOST=127.0.0.1
PORT=8848

# Maximum number of tasks (goals) that can run concurrently
MAX_CONCURRENT_TASKS=3

# Maximum number of turns per agent task (safety guard against runaway loops)
MAX_TURNS=40

# When the turn limit is hit before the goal is met, the maximum number of times to
# automatically resume the same session and continue.
# (0 disables auto-resume — leaves it incomplete for a manual /resume.) An upper bound to prevent cost blowup.
MAX_AUTO_RESUMES=3

# Permission mode: bypassPermissions (unattended autonomy) / acceptEdits / default
PERMISSION_MODE=bypassPermissions

# Publish auto-webhook (optional) — a no-code automation webhook URL (Make/Zapier/n8n, etc.).
# When set, publishing POSTs the artifact to this URL → wires up real auto-publishing to a blog/marketplace/social media.
# When left blank, artifacts are only staged in workspace/_ready_to_publish/ awaiting publication.
PUBLISH_WEBHOOK_URL=

# Payout account — the operator account where final earnings are deposited (to register in the platform's payout settings).
# The agent never accesses or transfers to this account. It is injected at runtime only for checklist guidance.
PAYOUT_ACCOUNT=BankName 000000000000

# Git synchronization of the knowledge store (knowledge/)
# When true, automatically git add+commit after save_knowledge (preserves the knowledge timeline)
KB_GIT_SYNC=false
# Also push to origin/main after the commit (requires git authentication)
KB_GIT_PUSH=false

# Notion MCP (optional) — when set, the Notion tools (mcp__notion__*) are exposed to the orchestrator/sub-agents.
# When left blank, the Notion feature itself is off. It runs over stdio via an external process (npx @notionhq/notion-mcp-server),
# so Node must be on PATH (this project already requires Node for builds).
# Token issuance: https://www.notion.so/my-integrations → New integration (Internal) → "Internal Integration Secret" (ntn_...)
# After issuing, on the target Notion page/DB open the "..." menu → Connections → add (share) this integration for access.
NOTION_TOKEN=
NOTION_VERSION=2022-06-28

# ── Channel (messenger) integration — Telegram bridge (channels/telegram_bridge.py) ──
# Bot token: message @BotFather on Telegram → /newbot, then paste the issued token here. Leave blank to disable the bridge.
TELEGRAM_BOT_TOKEN=
# Allowed sender chat_ids (comma-separated). If blank, anyone can drive the agent (dev only) — in production, always restrict to your own chat_id.
# Find your chat_id: send any message to the bot, then check chat.id at https://api.telegram.org/bot<token>/getUpdates
TELEGRAM_ALLOWED_CHAT_IDS=
# The agent-core API the bridge calls (default = local server). Change only when running on a different host.
AGENT_CORE_URL=

# Periodic routine scheduler — automatically submits registered routines (state/routines.json) as goals every interval_hours.
# When true, periodic tasks run automatically while the server is resident (a dedicated agent is spawned per routine). Set to false to disable.
SCHEDULER_ENABLED=true
# How often (in seconds) to check whether routines are due. Default 300 (5 min). Do not set this too short.
SCHEDULER_CHECK_SECONDS=300

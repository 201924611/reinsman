# Claude Agent SDK 인증 — 둘 중 하나만 있으면 됩니다.
# 1) API 키 방식 (권장: 무인 24h 구동에 안정적)
ANTHROPIC_API_KEY=sk-ant-...

# 2) 또는 Claude Code CLI 로그인 세션 사용 (키 비워두면 CLI 인증을 따라감)

# 중앙 에이전트가 사용할 모델
AGENT_MODEL=claude-opus-4-8

# 하위 에이전트 기본 모델 (비용 절감용으로 더 낮은 티어 가능)
SUBAGENT_MODEL=claude-sonnet-4-6

# HTTP 서버 바인딩
HOST=127.0.0.1
PORT=8848

# 동시에 돌릴 수 있는 최대 작업(목적) 수
MAX_CONCURRENT_TASKS=3

# 에이전트 1회 작업당 최대 turn 수 (폭주 방지 안전장치)
MAX_TURNS=40

# 턴 한도로 목표 미달 시, 같은 세션을 이어받아 자동으로 다시 이어할 최대 횟수
# (0이면 자동 이어하기 끔 — 미완료로 두고 수동 /resume). 비용 폭주 방지 상한.
MAX_AUTO_RESUMES=3

# 권한 모드: bypassPermissions(무인 자율) / acceptEdits / default
PERMISSION_MODE=bypassPermissions

# 배포 자동 발행 훅 (선택) — Make/Zapier/n8n 등 노코드 자동화 웹훅 URL.
# 설정하면 publish 시 이 URL로 산출물을 POST → 블로그/마켓/SNS 실제 자동 발행으로 연결.
# 비워두면 산출물은 workspace/_ready_to_publish/ 에 발행 대기 상태로만 적재된다.
PUBLISH_WEBHOOK_URL=

# 정산 수취 계좌 — 최종 수익이 입금될 운영자 계좌(플랫폼 정산 설정에 등록할 대상).
# 에이전트는 이 계좌에 접근/이체하지 않는다. 체크리스트 안내용으로만 런타임에 주입된다.
PAYOUT_ACCOUNT=은행명 000000000000

# 지식 저장소(knowledge/) git 동기화
# true면 save_knowledge 후 자동으로 git add+commit (지식 타임라인 보존)
KB_GIT_SYNC=false
# 커밋 후 origin/main 으로 push 까지 (git 인증 필요)
KB_GIT_PUSH=false

# 노션 MCP (선택) — 값이 있으면 오케스트레이터/서브에이전트에 notion 도구(mcp__notion__*)가 노출된다.
# 비워두면 노션 기능 자체가 꺼짐. 외부 프로세스(npx @notionhq/notion-mcp-server)로 stdio 구동되므로
# Node가 PATH에 있어야 한다(이 프로젝트는 빌드용으로 이미 Node 필요).
# 토큰 발급: https://www.notion.so/my-integrations → New integration(Internal) → "Internal Integration Secret"(ntn_...)
# 발급 후, 정리 대상이 될 노션 페이지/DB의 "..." 메뉴 → Connections → 이 integration 추가(공유)해야 접근 가능.
NOTION_TOKEN=
NOTION_VERSION=2022-06-28

# ── 채널(메신저) 연동 — 텔레그램 브리지(channels/telegram_bridge.py) ──
# 봇 토큰: 텔레그램 @BotFather 에게 /newbot → 발급받은 토큰을 넣는다. 비우면 브리지 비활성.
TELEGRAM_BOT_TOKEN=
# 허용 발신자 chat_id(쉼표 구분). 비우면 누구나 에이전트를 구동 가능(개발용) — 운영 시 반드시 본인 chat_id로 제한.
# 내 chat_id 확인: 봇에게 아무 메시지나 보낸 뒤 https://api.telegram.org/bot<토큰>/getUpdates 의 chat.id
TELEGRAM_ALLOWED_CHAT_IDS=
# 브리지가 호출할 agent-core API(기본 = 로컬 서버). 다른 호스트에서 돌릴 때만 변경.
AGENT_CORE_URL=

# 주기 루틴 스케줄러 — 등록한 루틴(state/routines.json)을 interval_hours마다 goal로 자동 제출.
# true면 서버 상주 중 주기 작업이 자동 실행됨(루틴마다 전용 에이전트 생성). 끄려면 false.
SCHEDULER_ENABLED=true
# 루틴 도래 점검 주기(초). 기본 300(5분). 너무 짧게 두지 말 것.
SCHEDULER_CHECK_SECONDS=300

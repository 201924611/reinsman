# Secrets/credentials — never commit
.env

# Runtime-generated files (auto-created by config.py) — comments must be on their own line (no inline comments)
state/
logs/
# Temporary md auto-deleted when a sub-agent exits
runtime_agents/
# Execution trace (tokens, tool chain) JSON
traces/
# Auto-grading result JSON
evals/
# Per-round screenshots from build_loop
round_shots/
# Raw site scratch for design research (large HTML/CSS)
workspace/_measure/
# Self-improvement proposals/backups (runtime — applied results are reflected in orchestrator.md/templates and tracked)
self_improve/
# workspace/ is tracked to share artifacts (to continue on another PC). Be careful about staging secrets.

# Node / Java build artifacts (huge — do not commit)
node_modules/
**/node_modules/
**/target/
**/.vite/

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/

# OS/editor
.DS_Store
Thumbs.db
.idea/
.vscode/
